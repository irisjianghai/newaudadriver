---

<Layout
  title="Products — VoltField Solutions"
  description="Browse our catalog of EV diagnostics, insulated tools, power supplies, and off-grid lighting. VDE/GS certified."
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <SectionHeading
      eyebrow="Product Catalog"
      title="Hardware that earns a place in your kit"
      description="Every product in our catalog is tested against VDE/GS standards before it reaches your workshop."
    />

    <div class="mt-12">
      <ProductsBrowser client:only="react" products={products} categories={categories} />
    </div>
  </div>
</Layout>