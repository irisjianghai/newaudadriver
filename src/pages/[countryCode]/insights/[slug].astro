---
// src/pages/[countryCode]/insights/[slug].astro
import Layout from "../../../layouts/Layout.astro";
import { getRegionParams } from "../../../lib/params/region-params";
import { getPost, posts } from "../../../lib/posts";

// ★★★ 自定义 getStaticPaths ★★★
export async function getStaticPaths() {
  // 1. 先获取所有 region 路径（国家代码）
  const regionPaths = await getRegionParams();
  
  // 2. 为每个 region 和每个文章生成路径
  const paths = [];
  for (const regionPath of regionPaths) {
    for (const post of posts) {
      paths.push({
        params: {
          countryCode: regionPath.params.countryCode,
          slug: post.slug,
        },
      });
    }
  }
  return paths;
}

const { countryCode, slug } = Astro.params;

// 查找文章
const post = getPost(slug);

if (!post) {
  return Astro.redirect("/404");
}

// 模拟相关产品数据
const relatedProducts = [
  {
    slug: "mso8104hd-high-res-oscilloscope",
    name: "MSO8104HD High-Resolution Oscilloscope",
    brand: "VoltField",
    image: "/images/product-oscilloscope.png",
    priceUSD: 399.00,
  },
  {
    slug: "bt3600-battery-internal-resistance-analyzer",
    name: "BT3600 Battery Internal Resistance Analyzer",
    brand: "VoltField",
    image: "/images/product-battery-analyzer.png",
    priceUSD: 599.00,
  },
  {
    slug: "vde-insulated-torque-wrench",
    name: "VDE Insulated Torque Wrench",
    brand: "VoltField",
    image: "/images/product-insulated-wrench.png",
    priceUSD: 129.00,
  },
  {
    slug: "it6015c-bidirectional-dc-power-supply",
    name: "IT6015C Bidirectional DC Power Supply",
    brand: "VoltField",
    image: "/images/product-power-supply.png",
    priceUSD: 1299.00,
  },
];
---

<Layout
  title={`${post.title} — VoltField Solutions`}
  description={post.excerpt}
>
  <article>
    <!-- ===== Hero ===== -->
    <header class="relative border-b border-[#1e293b]">
      <div class="absolute inset-0">
        <img
          src={post.image || '/placeholder.svg'}
          alt={post.title}
          class="h-full w-full object-cover opacity-25"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0F1115] to-[#0F1115]/50" />
      </div>
      <div class="relative mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:py-28">
        <a
          href={`/${countryCode}/insights`}
          class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wide text-gray-400 transition-colors hover:text-[#C6FF00]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          All insights
        </a>
        <span class="mt-6 inline-block bg-[#C6FF00] px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-wide text-[#0F1115]">
          {post.category}
        </span>
        <h1 class="mt-5 text-3xl font-bold leading-tight tracking-tight text-balance text-white sm:text-4xl lg:text-5xl">
          {post.title}
        </h1>
        <div class="mt-6 flex items-center gap-3 font-mono text-[11px] uppercase tracking-wide text-gray-400">
          <span>{post.date}</span>
          <span class="h-1 w-1 rounded-full bg-[#1e293b]" />
          <span>{post.readTime}</span>
        </div>
      </div>
    </header>

    <!-- ===== Body ===== -->
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
      <p class="border-l-2 border-[#C6FF00] pl-5 text-lg font-medium leading-relaxed text-pretty text-white">
        {post.excerpt}
      </p>
      <div class="mt-8 flex flex-col gap-6 leading-relaxed text-gray-400">
        {post.body.map((para, i) => (
          <p key={i} class="text-pretty">
            {para}
          </p>
        ))}
      </div>
    </div>

    <!-- ===== Shop the Story ===== -->
    {relatedProducts.length > 0 && (
      <section class="border-t border-[#1e293b] bg-[#0F1115]/40">
        <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
          <div class="flex items-center gap-3">
            <span class="h-px w-8 bg-[#FF5200]" />
            <h2 class="font-mono text-xs uppercase tracking-widest text-[#FF5200]">
              Shop the Story
            </h2>
          </div>
          <p class="mt-3 max-w-xl text-pretty leading-relaxed text-gray-400">
            The hardware referenced in this article. Every unit is
            spec-verified and ships from our East China hub.
          </p>
          <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {relatedProducts.slice(0, 4).map((product) => (
              <a
                key={product.slug}
                href={`/${countryCode}/products/${product.slug}`}
                class="group block overflow-hidden rounded-lg border border-[#1e293b] bg-[#1a1d23] transition-all hover:border-[#C6FF00]"
              >
                <div class="aspect-square overflow-hidden bg-[#0F1115]">
                  <img
                    src={product.image || '/placeholder.svg'}
                    alt={product.name}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="p-4">
                  <p class="font-mono text-[11px] uppercase tracking-wide text-[#C6FF00]">
                    {product.brand}
                  </p>
                  <h3 class="mt-1 text-sm font-medium text-white line-clamp-2 group-hover:text-[#C6FF00]">
                    {product.name}
                  </h3>
                  <p class="mt-2 text-lg font-bold text-[#C6FF00]">
                    ${product.priceUSD.toFixed(2)}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Layout>