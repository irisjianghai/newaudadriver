---
// src/components/SectionHeading.astro

export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const { eyebrow, title, description, align = "left", class: className } = Astro.props;

const isCenter = align === "center";
---

<div
  class={`max-w-2xl ${isCenter ? "mx-auto text-center" : ""} ${className || ""}`}
>
  {eyebrow && (
    <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-blue-600 dark:text-blue-400">
      {isCenter && <span class="h-px w-6 bg-blue-600 dark:bg-blue-400" />}
      {eyebrow}
      <span class="h-px w-6 bg-blue-600 dark:bg-blue-400" />
    </p>
  )}
  <h2 class="mt-3 text-3xl font-bold tracking-tight text-balance sm:text-4xl text-gray-900 dark:text-white">
    {title}
  </h2>
  {description && (
    <p class="mt-4 text-pretty leading-relaxed text-gray-600 dark:text-gray-400">
      {description}
    </p>
  )}
</div>